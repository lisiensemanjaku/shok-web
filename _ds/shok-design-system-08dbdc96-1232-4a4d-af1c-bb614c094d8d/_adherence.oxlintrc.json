      "--color-highlight-bg",
      "--color-overlay-medium",
      "--color-primary-green",
      "--color-primary-green-muted",
      "--color-primary-green-subtle",
      "--color-primary-yellow",
      "--color-shimmer-highlight",
      "--color-text-disabled",
      "--color-text-muted",
      "--color-text-on-accent",
      "--color-text-primary",
      "--color-text-quaternary",
      "--color-text-secondary",
      "--color-text-subtle",
      "--color-text-tertiary",
      "--font-body",
